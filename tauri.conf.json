{
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:3000",
    "frontendDist": ".next"
  },
  "package": {
    "productName": "Soundcloudy",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "execute": false,
        "sidecar": false,
        "open": true
      },
      "window": {
        "all": false,
        "create": true,
        "close": true,
        "minimize": true,
        "maximize": true,
        "unmaximize": true,
        "show": true,
        "hide": true
      }
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 900,
        "resizable": true,
        "title": "Soundcloudy - Your SoundCloud Player",
        "width": 1200,
        "minHeight": 600,
        "minWidth": 800
      }
    ],
    "security": {
      "csp": null
    }
  }
}
