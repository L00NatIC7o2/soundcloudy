{
  "productName": "Soundcloudy",
  "version": "1.0.0",
  "identifier": "com.soundcloudy.app",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "npm run dev",
    "devUrl": "https://soundcloudy.vercel.app",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "height": 900,
        "resizable": true,
        "title": "Soundcloudy - Your SoundCloud Player",
        "width": 1200,
        "minHeight": 600,
        "minWidth": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": ["icons/icon.ico"],
    "externalBin": ["node"],
    "resources": []
  }
}
