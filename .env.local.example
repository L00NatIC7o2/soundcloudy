SOUNDCLOUD_CLIENT_ID=your_soundcloud_client_id
SOUNDCLOUD_CLIENT_SECRET=your_soundcloud_client_secret

# Use your temporary tunnel URL while testing on phone.
NEXTAUTH_URL=https://your-web-tunnel.ngrok-free.app
NEXT_PUBLIC_APP_URL=https://your-web-tunnel.ngrok-free.app
NEXT_PUBLIC_SOCKET_URL=https://your-socket-tunnel.ngrok-free.app

# Private history web credentials are now scraped and stored per user session.
